[
  {
    "ayah": 1,
    "text": "Malheur à tout calomniateur diffamateur,"
  },
  {
    "ayah": 2,
    "text": "qui amasse une fortune et la compte,"
  },
  {
    "ayah": 3,
    "text": "pensant que sa fortune l'immortalisera."
  },
  {
    "ayah": 4,
    "text": "Mais non! Il sera certes, jeté dans la Hutamah."
  },
  {
    "ayah": 5,
    "text": "Et qui te dira ce qu'est la Hutamah?"
  },
  {
    "ayah": 6,
    "text": "Le Feu attisé d'Allah"
  },
  {
    "ayah": 7,
    "text": "qui monte jusqu'aux cœurs."
  },
  {
    "ayah": 8,
    "text": "Il se refermera sur eux,"
  },
  {
    "ayah": 9,
    "text": "en colonnes (de flammes) étendues."
  }
]
