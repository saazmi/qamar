{
  "name": "qamar",
  "version": "0.0.1",
  "private": true,
  "description": "Offline-first Quran memorization app for ADHD learners. See SPEC.md.",
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "content:build": "ts-node --transpile-only scripts/build-quran-content.ts",
    "content:verify": "ts-node --transpile-only scripts/verify-content.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@expo-google-fonts/amiri": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/noto-naskh-arabic": "^0.4.5",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "expo": "latest",
    "expo-av": "^16.0.8",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-router": "~57.0.4",
    "expo-sqlite": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@core/(.*)$": "<rootDir>/src/core/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@content/(.*)$": "<rootDir>/src/content/$1",
      "^@db/(.*)$": "<rootDir>/src/db/$1",
      "^@audio/(.*)$": "<rootDir>/src/audio/$1",
      "^@stores/(.*)$": "<rootDir>/src/stores/$1",
      "^@theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@i18n/(.*)$": "<rootDir>/src/i18n/$1"
    }
  }
}
